# Server
PORT=3001

# MySQL database (create one in Hostinger hPanel -> Databases -> MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Auth
JWT_SECRET=change-this-to-a-long-random-string

# Initial admin login (used only the first time, when the admins table is empty)
ADMIN_EMAIL=admin@hastavastra.com
ADMIN_PASSWORD=admin123
